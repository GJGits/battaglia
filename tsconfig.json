{
  "compilerOptions": {
    "incremental": true,
    "target": "es2022",
    "module": "node16",
    "lib": ["dom", "es2022"],
    "jsx": "react-jsx",
    "strict": true,
    "sourceMap": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": ".erb/dll"
  },
  "include": [
    "src", 
    "src/declarations.d.ts" // Forza l'inclusione se "src" non basta
  ],
  "exclude": ["test", "release/build", "release/app/dist", ".erb/dll"]
}
